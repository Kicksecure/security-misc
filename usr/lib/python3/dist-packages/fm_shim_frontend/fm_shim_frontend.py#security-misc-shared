class WidgetShowBinding(QObject):
    """
    Detects when a widget is shown or hidden, and shows or hides another
    widget in response.
    """

    def __init__(
        self, bound_widget: QWidget, parent: QObject | None = None
    ) -> None:
        """
        ScrollBarEventFilter constructor.
        """

        super().__init__(parent)

        self.bound_widget = bound_widget

    # pylint: disable=invalid-name, unused-argument
    def eventFilter(self, obj: QObject | None, event: QEvent | None) -> bool:
        """
        Shows or hides the bound widget when the binding widget is shown or
        hidden.
        """

        if event is None:
            return False

        # pylint: disable=no-member
        do_recalc_layout: bool = False
        if event.type() == QEvent.Type.Show:
            self.bound_widget.show()
            do_recalc_layout = True
        # pylint: disable=no-member
        elif event.type() == QEvent.Type.Hide:
            self.bound_widget.hide()
            do_recalc_layout = True
        if do_recalc_layout:
            parent_object: QObject | None = self.bound_widget.parent()
            assert parent_object is not None
            parent_widget: QWidget = cast(QWidget, parent_object)
            parent_layout: QLayout | None = parent_widget.layout()
            assert parent_layout is not None
            parent_layout.update()
        return False


class AnalyzePathsWindow(QDialog):
    """
    Helper window for analyzing unsafe characters in paths.
    """

    def __init__(
        self, dir_list: list[Path], parent: QDialog | None = None
    ) -> None:
        """
        AnalyzePathsWindow constructor.
        """

        super().__init__(parent)

        self.dir_list: list[Path] = dir_list
        self.has_unsafe_chars_list: list[bool] = []

        self.core_layout: QVBoxLayout = QVBoxLayout()
        self.dir_list_view: QListWidget = QListWidget()
        self.dir_list_view.resize(1, 50)
        # pylint: disable=no-member
        self.dir_list_view.setSizePolicy(
            QSizePolicy.Policy.Expanding,
            QSizePolicy.Policy.Fixed,
        )
        self.dir_list_view.currentRowChanged.connect(
            self.populate_unicode_show_view
        )
        self.core_layout.addWidget(self.dir_list_view)

        self.unicode_show_view: QTextEdit = QTextEdit()
        self.unicode_show_view.setReadOnly(True)
        # pylint: disable=no-member
        self.unicode_show_view.setLineWrapMode(QTextEdit.LineWrapMode.NoWrap)
        # pylint: disable=no-member
        self.unicode_show_view.setCurrentFont(
            QFontDatabase.systemFont(QFontDatabase.SystemFont.FixedFont)
        )
        self.core_layout.addWidget(self.unicode_show_view)

        self.button_layout: QHBoxLayout = QHBoxLayout()
        self.button_layout.addStretch()
        self.done_button: QPushButton = QPushButton("Done")
        self.done_button.clicked.connect(self.accept)
        self.button_layout.addWidget(self.done_button)
        self.core_layout.addLayout(self.button_layout)

        self.setLayout(self.core_layout)
        self.setWindowTitle("Analyze Paths")
        self.resize(690, 500)

        for dir_path in self.dir_list:
            qlwi: QListWidgetItem = QListWidgetItem(
                stdisplay(str(dir_path), sgr=-1)
            )
            if any(
                (not 0x20 <= ord(path_char) <= 0x7E)
                for path_char in str(dir_path)
            ):
                qlwi.setBackground(QBrush(QColor(255, 128, 128)))
                self.has_unsafe_chars_list.append(True)
            else:
                self.has_unsafe_chars_list.append(False)
            self.dir_list_view.addItem(qlwi)

        self.populate_unicode_show_view(-1)

    def populate_unicode_show_view(self, path_idx: int) -> None:
        """
        Runs the path through unicode-show and populates info about it in the
        unicode_show_view widget.
        """

        if path_idx < 0 or path_idx >= len(self.dir_list):
            self.unicode_show_view.setPlainText(
                "Select a file path to analyze above.\n"
                + "Paths highlighted in red contain potentially unsafe "
                + "characters."
            )
            return

        if self.has_unsafe_chars_list[path_idx]:
            try:
                unicode_show_output: str = subprocess.run(
                    ["/usr/bin/unicode-show"],
                    input=str(self.dir_list[path_idx]),
                    capture_output=True,
                    check=False,
                    encoding="utf-8",
                ).stdout
                self.unicode_show_view.setPlainText(unicode_show_output)
            except Exception:
                traceback.print_exc(file=sys.stderr)
                self.unicode_show_view.setPlainText(
                    "Unable to check this path for unsafe chars!\n"
                    + "See logs in 'journalctl --user --boot fm-shim.service' "
                    + "for more information."
                )
        else:
            self.unicode_show_view.setPlainText(
                "No unsafe chars found in the selected path."
            )


